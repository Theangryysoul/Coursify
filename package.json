{
  "name": "coursify",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.10.0",
      "onFail": "download"
    }
  },
  "scripts": {
    "client": "pnpm --filter client dev",
    "server": "pnpm --filter server dev",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format"
  }
}